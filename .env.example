# ─── The Feast Light – Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ── Google Sheets CMS ──────────────────────────────────────────────────────
# Your Google Spreadsheet ID (found in the URL):
# https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID_HERE/edit
VITE_SHEET_ID=

# Google API Key (required if your sheet is NOT publicly shared):
# Create at https://console.cloud.google.com → APIs → Credentials
# Enable "Google Sheets API" for this key
VITE_GOOGLE_API_KEY=

VITE_FAQ_SCRIPT_URL=

VITE_SUBTALK_SHEET_URL=

VITE_YOUTUBE_CHANNEL_ID=

VITE_SOUNDCLOUD_USER_ID=